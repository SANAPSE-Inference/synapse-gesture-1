{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/wasm", "regex": ".*\\.wasm$" },
        { "key": "Content-Type", "value": "application/octet-stream", "regex": ".*\\.data$" }
      ]
    }
  ]
}